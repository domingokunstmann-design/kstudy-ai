# ============================================
# KSTUDY AI — Variables de entorno
# Copia este archivo como .env.local en desarrollo
# En Vercel, agrégalas en Settings > Environment Variables
# ============================================

# ── Supabase ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ── Google OAuth ──────────────────────────
# Obtenlo en console.cloud.google.com > APIs > Credentials
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ── App URL ───────────────────────────────
# En desarrollo: http://localhost:3000
# En producción: https://tu-app.vercel.app
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app

# ── Cron secret ───────────────────────────
# Genera uno random: openssl rand -hex 32
CRON_SECRET=un-string-secreto-random

# ── Gemini AI (opcional pero recomendado) ─
# API key gratuita en aistudio.google.com
GEMINI_API_KEY=AIzaSyxxx...
